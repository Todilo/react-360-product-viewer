{
  "name": "react-360-product-viewer",
  "version": "0.2.10",
  "description": "Showcase your products in this 360 viewer component.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Todilo/react-360-product-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/Todilo/react-360-product-viewer/issues"
  },
  "homepage": "https://github.com/Todilo/react-360-product-viewer#readme",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@11.9.0",
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist storybook-static",
    "build": "npm run clean && npm run build-lib",
    "build-lib": "rollup -c",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "npm run typecheck && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "prepack": "npm run build",
    "chromatic": "chromatic"
  },
  "keywords": [
    "react",
    "360-viewer",
    "product-viewer",
    "storybook",
    "styled-components"
  ],
  "author": "Christian Klinton",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^4.1.3",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-docs": "^10.1.2",
    "@storybook/addon-links": "^10.1.2",
    "@storybook/addon-webpack5-compiler-babel": "^4.0.0",
    "@storybook/react-webpack5": "^10.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/mocker": "^4.0.14",
    "babel-loader": "^10.0.0",
    "chromatic": "^13.3.4",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.60.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.1.2",
    "styled-components": "^6.3.12",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": "react-app",
    "ignorePatterns": [
      "**/protos/*.ts"
    ]
  },
  "files": [
    "dist"
  ]
}
